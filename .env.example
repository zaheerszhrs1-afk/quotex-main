# Copy this file to .env.local and adjust as needed.

# MongoDB. If you have MongoDB installed locally, use the URI below.
# If left empty, the server falls back to an in-memory MongoDB (mongodb-memory-server)
# so the app runs without installing MongoDB. Data is lost on restart in that mode.
MONGODB_URI=mongodb://localhost:27017/quotex-clone

# Auth secrets — change these for anything beyond local testing.
JWT_SECRET=supersecretjwtkey123
JWT_REFRESH_SECRET=supersecretrefresh456

# Socket.io / Express server URL (used by the browser client).
NEXT_PUBLIC_WS_URL=http://localhost:5001
WS_PORT=5001

# Google OAuth ("Sign in via Google"). Create an OAuth 2.0 Client ID in the
# Google Cloud Console (APIs & Services → Credentials). Under "Authorized
# redirect URIs" add: http://localhost:3000/api/auth/google/callback (and your
# production URL). Leave these blank to disable Google sign-in gracefully — the
# button then shows a "coming soon" notice instead of erroring.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override the redirect URI if it can't be derived from the request
# origin (e.g. behind a proxy). Must exactly match a URI registered in Google.
GOOGLE_REDIRECT_URI=
# Set to "true" ONLY when the credentials above are filled in. This is a public
# (client-side) flag that turns the Google button into a real OAuth login;
# unset/false makes it show "coming soon". Build works fine when left blank.
NEXT_PUBLIC_GOOGLE_ENABLED=

# Seed admin credentials.
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=Admin123!

# Cloudinary (payment screenshot storage). If unset, files are saved to
# public/uploads (local dev only — lost on redeploy in production).
# Either paste the single URL from the Cloudinary dashboard:
CLOUDINARY_URL=
# ...or set the three values separately:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder (default: quotex/payments)
CLOUDINARY_FOLDER=

# --- Real "international market" live feeds (admin candle control) ---
# Crypto (BTC/USD, ETH/USD) uses Binance for both live + history — needs NO key.
#
# Finnhub (https://finnhub.io — free, unlimited symbols) provides LIVE prices for
# forex + commodities (OANDA) and stocks: EUR/USD, GBP/USD, USD/JPY, AUD/USD,
# Gold, Oil, AAPL, TSLA, AMZN, GOOGL, MSFT, META, NFLX, NVDA.
FINNHUB_KEY=
# Twelve Data (https://twelvedata.com — free) provides HISTORY (scrollback) for
# those non-crypto assets. Free tier is 8 credits/min, so backfill uses only 3
# calls per asset (1min/1h/1day); toggle assets live one at a time if you hit it.
# Non-crypto assets need BOTH keys (Finnhub=live, Twelve Data=history); without
# them that asset stays simulated and its live toggle is disabled.
TWELVE_DATA_KEY=
